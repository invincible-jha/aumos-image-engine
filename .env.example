# ============================================================================
# .env.example — aumos-image-engine environment variables
# ============================================================================
# Copy to .env and customize for local development:
#   cp .env.example .env
# ============================================================================

# Service Identity
AUMOS_SERVICE_NAME=aumos-image-engine
AUMOS_ENVIRONMENT=development
AUMOS_DEBUG=true

# Database (PostgreSQL 16 + pgvector + RLS)
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos
AUMOS_DATABASE__POOL_SIZE=10
AUMOS_DATABASE__ECHO=false

# Kafka (Apache Kafka + Protobuf Schema Registry)
AUMOS_KAFKA__BROKERS=localhost:9092
AUMOS_KAFKA__SCHEMA_REGISTRY_URL=http://localhost:8081

# Authentication (Keycloak)
AUMOS_KEYCLOAK__URL=http://localhost:8080
AUMOS_KEYCLOAK__REALM=aumos
AUMOS_KEYCLOAK__CLIENT_ID=aumos-image-engine
AUMOS_KEYCLOAK__CLIENT_SECRET=dev-secret-change-in-production

# Observability
AUMOS_OTEL_ENDPOINT=http://localhost:4317
AUMOS_OTEL_ENABLED=false
AUMOS_LOG_LEVEL=DEBUG
AUMOS_LOG_FORMAT=console

# Object Storage (MinIO)
AUMOS_MINIO__URL=http://localhost:9000
AUMOS_MINIO__ACCESS_KEY=minioadmin
AUMOS_MINIO__SECRET_KEY=minioadmin
AUMOS_MINIO__DEFAULT_BUCKET=aumos-images

# Redis
AUMOS_REDIS__URL=redis://localhost:6379/0

# ============================================================================
# IMAGE ENGINE — SPECIFIC SETTINGS
# ============================================================================

# GPU Configuration
GPU_ENABLED=true
CUDA_VISIBLE_DEVICES=0

# Privacy Engine (face de-identification + biometric verification)
PRIVACY_ENGINE_URL=http://localhost:8010

# Stable Diffusion model configuration
AUMOS_IMG__SD_MODEL_ID=runwayml/stable-diffusion-v1-5
AUMOS_IMG__SD_DEVICE=cuda
AUMOS_IMG__SD_DTYPE=float16
AUMOS_IMG__MODEL_CACHE_DIR=/app/model_cache

# BlenderProc 3D generation
AUMOS_IMG__BLENDERPROC_ENABLED=false
AUMOS_IMG__BLENDERPROC_OUTPUT_DIR=/tmp/blenderproc_output

# Face de-identification settings
AUMOS_IMG__FACE_DETECTION_CONFIDENCE=0.9
AUMOS_IMG__FACE_DEIDENTIFICATION_STRENGTH=0.8
AUMOS_IMG__PRESERVE_EXPRESSION=true

# C2PA provenance signing
AUMOS_IMG__C2PA_ENABLED=true
AUMOS_IMG__C2PA_SIGNING_KEY_PATH=/run/secrets/c2pa_signing_key
AUMOS_IMG__C2PA_CERT_PATH=/run/secrets/c2pa_cert

# Watermarking
AUMOS_IMG__WATERMARK_ENABLED=true
AUMOS_IMG__WATERMARK_STRENGTH=0.3

# Biometric verification (NIST FRVT compliance)
AUMOS_IMG__BIOMETRIC_VERIFICATION_ENABLED=true
AUMOS_IMG__FRVT_THRESHOLD=0.05

# Batch processing
AUMOS_IMG__BATCH_MAX_SIZE=100
AUMOS_IMG__BATCH_CONCURRENCY=4
